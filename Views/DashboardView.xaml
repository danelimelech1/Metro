<UserControl x:Class="Metro.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             FlowDirection="RightToLeft">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Welcome Header -->
            <TextBlock Text="{Binding WelcomeMessage}" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource MahApps.Brushes.Accent}"
                       Margin="0,0,0,20"/>

            <TextBlock Text="סיכום כללי" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"
                       Margin="0,0,0,12"/>

            <!-- Stats Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,24">

                <Border Background="#1E2A3A" CornerRadius="10" Margin="0,0,10,0" Padding="20"
                        BorderThickness="1" BorderBrush="#2A3F55">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalUsers}" FontSize="36" FontWeight="Bold"
                                   Foreground="#64B5F6" HorizontalAlignment="Center"/>
                        <TextBlock Text="משתמשים" FontSize="13"
                                   Foreground="{DynamicResource MahApps.Brushes.SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#1A2E1A" CornerRadius="10" Margin="0,0,10,0" Padding="20"
                        BorderThickness="1" BorderBrush="#2A4A2A">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalProducts}" FontSize="36" FontWeight="Bold"
                                   Foreground="#81C784" HorizontalAlignment="Center"/>
                        <TextBlock Text="מוצרים" FontSize="13"
                                   Foreground="{DynamicResource MahApps.Brushes.SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#2E2A18" CornerRadius="10" Margin="0,0,10,0" Padding="20"
                        BorderThickness="1" BorderBrush="#4A4020">
                    <StackPanel>
                        <TextBlock Text="📋" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalOrders}" FontSize="36" FontWeight="Bold"
                                   Foreground="#FFD54F" HorizontalAlignment="Center"/>
                        <TextBlock Text="הזמנות" FontSize="13"
                                   Foreground="{DynamicResource MahApps.Brushes.SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#2E1A20" CornerRadius="10" Padding="20"
                        BorderThickness="1" BorderBrush="#4A2530">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalRevenue, StringFormat='₪{0:N0}'}"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="#F48FB1" HorizontalAlignment="Center"/>
                        <TextBlock Text="הכנסות" FontSize="13"
                                   Foreground="{DynamicResource MahApps.Brushes.SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Quick Info -->
            <TextBlock Text="מידע מהיר" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"
                       Margin="0,0,0,12"/>

            <Border Background="{DynamicResource MahApps.Brushes.Control.Background}"
                    CornerRadius="10" Padding="20" BorderThickness="1"
                    BorderBrush="{DynamicResource MahApps.Brushes.Border.NonActive}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="פעולות אחרונות" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource MahApps.Brushes.Text}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="• התחברות מוצלחת" Foreground="#66BB6A" Margin="0,2"/>
                        <TextBlock Text="• מערכת פעילה ותקינה" Foreground="#66BB6A" Margin="0,2"/>
                        <TextBlock Text="• גיבוי אחרון: לפני שעה"
                                   Foreground="{DynamicResource MahApps.Brushes.SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="סטטוס מערכת" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource MahApps.Brushes.Text}"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="10" Height="10" Fill="#66BB6A" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="בסיס נתונים: מחובר"
                                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="10" Height="10" Fill="#66BB6A" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="שרת: פעיל"
                                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="10" Height="10" Fill="#FFB300" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="סנכרון: ממתין"
                                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
