<mah:MetroWindow
    x:Class="Metro.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    Title="Metro - התחברות"
    Width="450" Height="580"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    FlowDirection="RightToLeft"
    GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
    BorderThickness="1">

    <Grid Background="{DynamicResource MahApps.Brushes.ThemeBackground}">

        <StackPanel VerticalAlignment="Center" Margin="50,0">

            <!-- Logo -->
            <Border Background="{DynamicResource MahApps.Brushes.Accent4}"
                    CornerRadius="50" Width="90" Height="90"
                    Margin="0,0,0,20" HorizontalAlignment="Center">
                <TextBlock Text="M" FontSize="48" FontWeight="Bold"
                           Foreground="{DynamicResource MahApps.Brushes.Accent}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Metro" FontSize="34" FontWeight="Bold"
                       Foreground="{DynamicResource MahApps.Brushes.Accent}"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="מערכת ניהול עסקית" FontSize="14"
                       Foreground="{DynamicResource MahApps.Brushes.SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <!-- Login Card -->
            <Border Background="{DynamicResource MahApps.Brushes.Control.Background}"
                    CornerRadius="12" Padding="30,25"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource MahApps.Brushes.Border.NonActive}">
                <StackPanel>
                    <TextBlock Text="כניסה למערכת" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource MahApps.Brushes.Accent}"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="שם משתמש"
                               Foreground="{DynamicResource MahApps.Brushes.Text}"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBox
                        x:Name="UsernameBox"
                        mah:TextBoxHelper.Watermark="הכנס שם משתמש"
                        Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        FontSize="14" Height="40" Margin="0,0,0,14"/>

                    <TextBlock Text="סיסמא"
                               Foreground="{DynamicResource MahApps.Brushes.Text}"
                               FontSize="12" Margin="0,0,0,4"/>
                    <PasswordBox
                        x:Name="PasswordBox"
                        mah:TextBoxHelper.Watermark="הכנס סיסמא"
                        FontSize="14" Height="40" Margin="0,0,0,6"
                        PasswordChanged="PasswordBox_PasswordChanged"/>

                    <TextBlock Text="ברירת מחדל: admin / admin123"
                               Foreground="{DynamicResource MahApps.Brushes.SystemControlForegroundBaseMediumBrush}"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#EF5350" FontSize="12"
                               HorizontalAlignment="Center"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                               Margin="0,0,0,10"/>

                    <Button Content="כניסה"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource MahApps.Styles.Button.Flat}"
                            Background="{DynamicResource MahApps.Brushes.Accent}"
                            Foreground="White"
                            FontSize="15" FontWeight="SemiBold"
                            Height="42" BorderThickness="0"
                            Cursor="Hand" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="© 2025 Metro Management System"
                       Foreground="{DynamicResource MahApps.Brushes.SystemControlForegroundBaseMediumBrush}"
                       FontSize="11" HorizontalAlignment="Center" Margin="0,20,0,0"/>
        </StackPanel>

        <!-- Loading Overlay -->
        <Grid Background="#A0000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <mah:ProgressRing IsActive="True" Width="60" Height="60"
                              Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
        </Grid>
    </Grid>
</mah:MetroWindow>
